# BOE RAG Assistant — local configuration template.
#
# Copy this file to `.env` (which is git-ignored) and fill in what you need:
#     cp .env.example .env        # macOS/Linux
#     Copy-Item .env.example .env # Windows PowerShell
#
# `.env` is loaded at app/CLI startup by boe_rag.settings.load_environment().
# A real environment variable always overrides the value here.
# Every key is OPTIONAL — unset keys fall back to the code's defaults.

# --- LLM providers (at least one key is required for answer generation) ------
# Tried in this order; the first with a key leads the fallback chain.
OPENROUTER_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# Optional model overrides (otherwise the built-in defaults are used).
# OPENROUTER_MODEL=
# GROQ_MODEL=
# GEMINI_MODEL=

# --- Serving paths (defaults are fine for local runs) ------------------------
# BOE_CORPUS_PATH=data/corpus/boe-2024.parquet
# BOE_EMBEDDINGS_PATH=data/embeddings/boe-2024.npz
# BOE_REPORTS_DIR=reports

# --- Qdrant vector backend (optional; Arc 5) ---------------------------------
# When QDRANT_URL is set, the dense leg is served from Qdrant instead of the
# in-memory NumPy index. Requires the `qdrant` extra: pip install -e .[qdrant]
# Build the collection first: python scripts/build_qdrant_index.py
# QDRANT_URL=http://localhost:6333
# QDRANT_COLLECTION=boe_chunks
# QDRANT_API_KEY=

# --- Observability (optional; enables Langfuse tracing when both are set) -----
# Requires the `obs` extra: pip install -e .[obs]
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
