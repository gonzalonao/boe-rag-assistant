# Keep the build context small and reproducible: the corpus and embeddings are
# fetched/generated during the build, not copied from the host.
.git/
.github/
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

.ruff_cache/
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/

.env
.env.*

data/
models/
eval_data/
tests/

.DS_Store
Thumbs.db
.idea/
.vscode/
